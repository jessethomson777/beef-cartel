# ============================================================================
# Beef Cartel — apps/web environment. Copy to .env.local and fill in.
# Vars prefixed NEXT_PUBLIC_* are exposed to the browser (safe public values).
# Everything else is server-only and must NOT be NEXT_PUBLIC.
# On Firebase App Hosting these are set in apphosting.yaml: NEXT_PUBLIC_* + the
# non-secret server vars as plain `env`; the three secrets as Secret Manager refs.
# ============================================================================

# ---- Firebase web config (public; from Firebase console → Project settings) ----
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Stripe (TEST keys to start; see README for the live switch) ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Resend (transactional email) ----
RESEND_API_KEY=re_xxx

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Server-only config (NOTE: beyond your original var list, but required) ----
# Admin SDK uses Application Default Credentials; projectId helps it locally.
FIREBASE_PROJECT_ID=
# Comma-separated emails allowed into /admin and admin APIs (your brother).
ADMIN_EMAILS=
# Where the aggregated supplier PO email is sent.
SUPPLIER_EMAIL=
# From-address for all transactional email (must be a Resend-verified sender/domain).
EMAIL_FROM=Beef Cartel <orders@beefcartel.com.au>
