{
  "name": "@beef-cartel/design-system",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Beef Cartel — premium boxed-beef preorder design system (tokens + React components). Single source of truth in src/theme/tokens.ts. Consumed by apps/web via transpilePackages; also runs a standalone /preview (npm run dev) and syncs to Claude Design via /design-sync.",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme/index.ts",
    "./global.css": "./src/theme/global.css",
    "./tokens": "./src/theme/tokens.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
